# Copy this file to `.env` in your project root and fill in the keys for the
# AI provider(s) you want to use. .env is gitignored.

# Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=

# Optional: override default models
# ZVR_ANTHROPIC_MODEL=claude-sonnet-4-5
# ZVR_OPENAI_MODEL=gpt-4o
